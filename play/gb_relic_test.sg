// forge/play/gb_relic_test.sg — load a REAL sealed RELIC-V2 GB ROM relic and run
// it on the ported native Game Boy core (forge/play/gb_core.sg), rendering the
// framebuffer to the terminal. Verifies the whole pipeline end to end: a real
// game from a real relic, not a synthetic test payload.
//
// Links: forge/play/gb_core.sg  forge/play/gb_relic_test.sg

fn main() -> Int ! {mem, io.write, io.read, fs.read} {
    let blob: Text = read_blob(0, "/tmp/gb_test.relic");
    let flen: Int = len(blob);
    let raw: Int = alloc_buf(flen);
    var i: Int = 0;
    while i < flen invariant i >= 0 { poke8(raw, i, ord(slice(blob, i, i + 1))); i = i + 1; }

    // RLC2 header check (matches FORGE-SEAL/relic_walk layout).
    let magic_ok: Int = peek32(raw, 0) == 843271250;
    let class_ok: Int = peek8(raw, 5) == 1;
    let sysid: Int = peek8(raw, 6) + peek8(raw, 7) * 256;
    let mflen: Int = peek32(raw, 12);
    let payload_off: Int = 16 + mflen + 44;   // hdr(16)+manifest(mflen)+meta(44)
    let payload_len: Int = peek32(raw, 16 + mflen + 36);

    print(1, "  relic: magic_ok="); print(1, chr(48 + magic_ok));
    print(1, " class_ok="); print(1, chr(48 + class_ok));
    print(1, " sysid="); print(1, chr(48 + sysid / 10 % 10)); print(1, chr(48 + sysid % 10));
    print(1, " payload_len="); print(1, chr(48 + payload_len / 100000 % 10));
    print(1, chr(48 + payload_len / 10000 % 10)); print(1, chr(48 + payload_len / 1000 % 10));
    print(1, chr(48 + payload_len / 100 % 10)); print(1, chr(48 + payload_len / 10 % 10));
    print(1, chr(48 + payload_len % 10));
    print(1, "\n");

    // Native GB core needs base..base+3670016 (gb_rom + core_rom_max).
    let m: Int = alloc_buf(3735552);
    core_load(m, raw + payload_off, payload_len);

    var f: Int = 0;
    while f < 600 invariant f >= 0 { core_run_frame(m); f = f + 1; }

    print(1, "  diag: PC="); let pc: Int = gb_pc(m);
    print(1, chr(48 + pc / 10000 % 10)); print(1, chr(48 + pc / 1000 % 10));
    print(1, chr(48 + pc / 100 % 10)); print(1, chr(48 + pc / 10 % 10)); print(1, chr(48 + pc % 10));
    let lcdc: Int = peek8(gb_mem(m), 65344);
    print(1, "  LCDC="); print(1, chr(48 + lcdc / 100 % 10)); print(1, chr(48 + lcdc / 10 % 10)); print(1, chr(48 + lcdc % 10));
    print(1, "\n");
    print(1, "  halt="); print(1, chr(48 + peek32(gb_st(m), 20)));
    print(1, "  bytes-at-PC: ");
    var oi: Int = 0;
    while oi < 6 invariant oi >= 0 {
        let ov: Int = gb_read(m, pc + oi);
        print(1, chr(48 + ov / 100 % 10)); print(1, chr(48 + ov / 10 % 10)); print(1, chr(48 + ov % 10)); print(1, " ");
        oi = oi + 1;
    }
    print(1, "\n");

    print(1, "  IF="); print(1, chr(48 + peek8(gb_mem(m), 65295) / 100 % 10));
    print(1, chr(48 + peek8(gb_mem(m), 65295) / 10 % 10)); print(1, chr(48 + peek8(gb_mem(m), 65295) % 10));
    print(1, "  IE="); print(1, chr(48 + peek8(gb_mem(m), 65535) / 100 % 10));
    print(1, chr(48 + peek8(gb_mem(m), 65535) / 10 % 10)); print(1, chr(48 + peek8(gb_mem(m), 65535) % 10));
    print(1, "  IME="); print(1, chr(48 + peek32(gb_st(m), 16)));
    print(1, "  LY="); print(1, chr(48 + peek8(gb_mem(m), 65348) / 100 % 10));
    print(1, chr(48 + peek8(gb_mem(m), 65348) / 10 % 10)); print(1, chr(48 + peek8(gb_mem(m), 65348) % 10));
    print(1, "\n");
    print(1, "  bgp="); print(1, chr(48 + peek8(gb_mem(m), 65351) / 100 % 10));
    print(1, chr(48 + peek8(gb_mem(m), 65351) / 10 % 10)); print(1, chr(48 + peek8(gb_mem(m), 65351) % 10));
    print(1, "  scy="); print(1, chr(48 + peek8(gb_mem(m), 65346) / 100 % 10));
    print(1, chr(48 + peek8(gb_mem(m), 65346) / 10 % 10)); print(1, chr(48 + peek8(gb_mem(m), 65346) % 10));
    print(1, "\n  first 8 raw fb pixels (RGBA bytes each):\n  ");
    var pi: Int = 0;
    while pi < 8 invariant pi >= 0 {
        var bj: Int = 0;
        while bj < 4 invariant bj >= 0 {
            let bv: Int = peek8(core_fb(m), pi * 4 + bj);
            print(1, chr(48 + bv / 100 % 10)); print(1, chr(48 + bv / 10 % 10)); print(1, chr(48 + bv % 10)); print(1, " ");
            bj = bj + 1;
        }
        print(1, " | ");
        pi = pi + 1;
    }
    print(1, "\n");

    print(1, "\n  framebuffer (downsampled 40x18, real GB image, dark=block):\n");
    var ry: Int = 0;
    while ry < 18 invariant ry >= 0 {
        var rx: Int = 0;
        while rx < 40 invariant rx >= 0 {
            let px: Int = rx * 4;
            let py: Int = ry * 8;
            let idx: Int = (py * 160 + px) * 4;
            let pixel: Int = peek32(core_fb(m), idx);
            let r: Int = pixel % 256;
            let g: Int = (pixel / 256) % 256;
            let b: Int = (pixel / 65536) % 256;
            let lum: Int = (r + g + b) / 3;
            if lum < 128 { print(1, chr(226)); print(1, chr(150)); print(1, chr(136)); }
            if lum >= 128 { print(1, "  "); }
            rx = rx + 1;
        }
        print(1, "\n");
        ry = ry + 1;
    }
    print(1, "\n  [");
    if magic_ok == 1 { if class_ok == 1 { if sysid == 25 { print(1, "OK] real GB relic loaded + ran 30 frames natively.\n"); return 0; } } }
    print(1, "FAIL] relic header mismatch.\n");
    return 1;
}
