// forge/play/gamegear_boot_test.sg — verifies the ported Game Gear/SMS core (Z80
// CPU) executes a hand-assembled program natively: exact expected register outcome.
//
// Links: forge/play/z80_core.sg forge/play/psg_gg_core.sg forge/play/sms_vdp_core.sg
//        forge/play/sms_core.sg forge/play/gamegear_core.sg forge/play/gamegear_boot_test.sg

fn chk(cond: Int, pass: Int) -> Int { if cond == 1 { return pass + 1; } return pass; }

fn main() -> Int ! {mem, io.write} {
    let rom: Int = alloc_buf(4096);
    // LD A,0x10 (3E 10) ; INC A (3C) ; INC A (3C) ; INC A (3C)
    poke8(rom, 0, 62); poke8(rom, 1, 16);
    poke8(rom, 2, 60);
    poke8(rom, 3, 60);
    poke8(rom, 4, 60);

    let m: Int = alloc_buf(1310720);
    let ok: Int = core_load(m, rom, 4096);

    var pass: Int = 0;
    var tot: Int = 0;
    tot = tot + 1; pass = chk(ok == 1, pass);
    tot = tot + 1; pass = chk(z80_pc(m) == 0, pass);   // z80_reset always starts PC=0 (real Z80 behavior)

    z80_step(m); z80_step(m); z80_step(m); z80_step(m);   // LD A,n + 3x INC A

    let a: Int = z80_a(m);
    let pc: Int = z80_pc(m);
    tot = tot + 1; pass = chk(a == 19, pass);    // 0x10 + 3 = 19
    tot = tot + 1; pass = chk(pc == 5, pass);    // 2 + 1 + 1 + 1 = 5 bytes consumed

    // Real Game Gear specifics: gg_on() + LCD-crop wiring exist and run without crashing.
    gg_on(m);
    gg_crop(m);
    tot = tot + 1; pass = chk(gg_fb_w() == 160, pass);
    tot = tot + 1; pass = chk(gg_fb_h() == 144, pass);

    print(1, "GAME GEAR BOOT: Z80 CPU (SMS/GG shared), LD+INC hand-assembled program\n");
    print(1, "  core_load ok="); print(1, chr(48 + ok));
    print(1, "  after 4 steps: A="); print(1, chr(48 + a / 10 % 10)); print(1, chr(48 + a % 10));
    print(1, " (expect 19 = 0x10+3)  PC="); print(1, chr(48 + pc));
    print(1, " (expect 5)  gg_crop ran clean\n");
    print(1, "  SELFTEST: "); print(1, chr(48 + pass)); print(1, "/"); print(1, chr(48 + tot));
    if pass == tot { print(1, " PASS\n"); }
    if pass != tot { print(1, " FAIL\n"); }
    return tot - pass;
}
