// Shape tokens (docs/DESIGN_LANGUAGE.md §5) — corner radii in points.
fn lc_rad_ctl() -> Int { return 8; }      // buttons, fields, pills
fn lc_rad_card() -> Int { return 12; }    // cards, panels
fn lc_rad_window() -> Int { return 16; }  // windows

// Spacing tokens (§4) — 8px base grid.
fn lc_sp_xs() -> Int { return 4; }
fn lc_sp_sm() -> Int { return 8; }
fn lc_sp_md() -> Int { return 12; }
fn lc_sp_lg() -> Int { return 16; }
fn lc_sp_xl() -> Int { return 24; }
fn lc_sp_xxl() -> Int { return 32; }
