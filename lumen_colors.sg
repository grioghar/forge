// forge/lumen_colors.sg — the Lumen design tokens (sigil-os cc0/tokens.sg,
// docs/DESIGN_LANGUAGE.md), ported for Forge's native GUI backends. These are
// the REAL tokens sigilOS's own compositor/libwin use — not an invented
// palette — so Forge looks like Lumen today on macOS and matches exactly
// once it runs on Lumen itself.
//
// Each channel is precomputed as its IEEE-754 double bit pattern for
// channel/255.0 (0.0-1.0), since wm_pal_macos.sg feeds these straight into
// NSColor colorWithRed:green:blue:alpha: via dyld_call_rect (verified against
// a small C reference: memcpy(&bits, &(double){N}, 8) — see sigil#188).
//
// Dark theme only for now (Lumen's canonical theme, tokens.sg role 0).
// Light-mode/night-mode swap is a real Lumen feature (sigil-os#10) not yet
// ported here.

// surface/base #0B0D15 — deepest background (the window body)
fn lc_surface_base_r() -> Int { return 4586377554639066646; }
fn lc_surface_base_g() -> Int { return 4587507869839661594; }
fn lc_surface_base_b() -> Int { return 4590598575466288405; }

